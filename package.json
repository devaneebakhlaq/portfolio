{
  "name": "portfolio-fullstack",
  "version": "1.0.0",
  "description": "Fullstack Portfolio Application",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run build:frontend && npm run client\"",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "server": "npm start --prefix backend",
    "dev:server": "npm run dev --prefix backend",
    "client": "npm run preview --prefix frontend",
    "dev:client": "npm run dev --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "install:all": "npm install --prefix backend && npm install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
